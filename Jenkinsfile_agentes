pipeline {
    agent any // Agente por defecto para la orquestación y el despliegue (Nodo principal)

    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
        S3_BUCKET          = 'aws-sam-cli-managed-default-samclisourcebucket-w2rxf671dndk'
        AGENTE_ESTATICO    = 'static_agent' 
        AGENTE_REST        = 'rest_agent'
    }

    stages {
        /*
         * ==========================================================
         * ETAPA: ANÁLISIS ESTÁTICO (Solo en flujo CI - Rama develop)
         * Ejecutado en el Agente especializado en analisis estatico
         * ==========================================================
         */
        stage('Static Analysis') {
            //when { branch 'develop' }
            agent { label "${env.AGENTE_ESTATICO}" }
            steps {
                echo "Ejecutando análisis estático en agente dedicado: ${env.NODE_NAME}"
                sh '''
				echo "=== IDENTIDAD DEL AGENTE ESTÁTICO ==="
                whoami
                hostname
                echo "======================================"
                python3 -m venv venv_estatico
                . venv_estatico/bin/activate
                pip install flake8 bandit
                flake8 src/
                bandit -r src/
                deactivate
                '''
            }
        }

        /*
         * ==========================================================
         * ETAPA: GET CODE (Común para CI y CD)
         * ==========================================================
         */
        stage('Get Code') {
            steps {
                echo "Descargando código en el agente por defecto..."
                checkout scm
            }
        }

        /*
         * ==========================================================
         * ETAPA: DEPLOY (Inyección de Credenciales AWS)
         * ==========================================================
         */
        stage('Deploy') {
            steps {
                script {
                    // Capturamos de forma segura la rama real si BRANCH_NAME no está definido
                    def actualBranch = env.BRANCH_NAME ?: sh(script: 'git rev-parse --abbrev-ref HEAD', returnStdout: true).trim()
                    echo "Rama detectada en el sistema: ${actualBranch}"

                    if (actualBranch == 'develop' || actualBranch == 'origin/develop') {
                        env.STACK_NAME = 'todo-list-aws-staging'
                        env.STAGE_PARAM = 'staging'
                    } else {
                        env.STACK_NAME = 'todo-list-aws-production'
                        env.STAGE_PARAM = 'production'
                    }
                echo "Desplegando Stack ${env.STACK_NAME} en el agente por defecto..."
                
                // Envolvemos el entorno con el bloque de credenciales de AWS secretas
               withCredentials([
                    string(credentialsId: 'aws-access-key', variable: 'SEC_ACCESS_KEY'),
                    string(credentialsId: 'aws-secret-key', variable: 'SEC_SECRET_KEY'),
                    string(credentialsId: 'aws-session-token', variable: 'SEC_SESSION_TOKEN')
                ]) {
				
                    sh '''
                    echo "=== IDENTIDAD DEL AGENTE DE DESPLIEGUE ==="
                    whoami
                    hostname
                    echo "=========================================="
                    
					# Mapeamos las variables seguras a las variables estándar que busca AWS CLI y SAM
                    export AWS_ACCESS_KEY_ID="${SEC_ACCESS_KEY}"
                    export AWS_SECRET_ACCESS_KEY="${SEC_SECRET_KEY}"
                    export AWS_SESSION_TOKEN="${SEC_SESSION_TOKEN}"
                    export AWS_DEFAULT_REGION="us-east-1"
					
					sam build
                    
                    sam deploy \
                        --stack-name ${STACK_NAME} \
                        --s3-bucket ${S3_BUCKET} \
                        --capabilities CAPABILITY_IAM \
                        --no-confirm-changeset \
                        --no-fail-on-empty-changeset \
                        --parameter-overrides Stage="${STAGE_PARAM}"
                    
                    # Extraemos la URL y la guardamos en un fichero
                    aws cloudformation describe-stacks \
                        --stack-name ${STACK_NAME} \
                        --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                        --output text > api_url.txt
                    '''
                }
                
                // Guardamos el archivo con la url
                stash name: 'api-endpoint', includes: 'api_url.txt'
            }
        }

        /*
         * ==========================================================
         * ETAPA: REST TEST (Ejecutado en Agente de Pruebas dedicado)
         * ==========================================================
         */
        stage('Rest Test') {
            agent { label "${env.AGENTE_REST}" }
            steps {
                echo "Arrancando pruebas de API en agente dedicado: ${env.NODE_NAME}"
                
                // Recuperamos el archivo con la URL que guardó el agente anterior
                unstash 'api-endpoint'
                
                sh '''
                # Leemos el archivo recuperado y lo asignamos a la variable de entorno del agente
                export API_URL=$(cat api_url.txt)
                echo "URL recuperada con éxito en el agente de pruebas: $API_URL"
                
                python3 -m venv venv_integration
                . venv_integration/bin/activate
                pip install pytest requests
                
                export BASE_URL=$API_URL
                
                # Ejecución condicional: CI (Todos los tests) vs CD (Solo lectura)
                if [ "${BRANCH_NAME}" = "develop" ]; then
                    echo "Flujo CI detectado: Ejecutando suite completa de integración..."
                    pytest --junitxml=result-integration.xml test/integration/todoApiTest.py
                else
                    echo "Flujo CD detectado: Limitando a pruebas de Solo Lectura..."
                    pytest -k "listtodos" --junitxml=result-production.xml test/integration/todoApiTest.py
                fi
                
                deactivate
                '''
            }
            post {
                always {
                    script {
                        def reportFile = (env.BRANCH_NAME == 'develop') ? 'result-integration.xml' : 'result-production.xml'
                        junit testResults: reportFile, allowEmptyResults: true
                    }
                }
            }
        }

        /*
         * ============================================================================
         * ETAPA: PROMOTE (Solo se activa en la rama develop para automatizar el merge)
         * ============================================================================
         */
        stage('Promote') {
            when {
                expression {
                    def actualBranch = env.BRANCH_NAME ?: sh(script: 'git rev-parse --abbrev-ref HEAD', returnStdout: true).trim()
                    return (actualBranch == 'develop' || actualBranch == 'origin/develop')
                }
            }
            steps {
                echo 'Promocionando código a producción (Merge de Develop -> master)...'
                
                withCredentials([usernamePassword(credentialsId: 'Jenkins', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                    sh '''
                    git config user.name "crs"
                    
                    
                    # Traemos la rama master limpia del servidor
                    git fetch origin master:master
                    git checkout master
                    
                    # Hacemos merge de los cambios aprobados
                    git merge origin/develop --no-edit
                    
                    # Inyectamos credenciales de manera segura para hacer push al repositorio remoto
                    git remote set-url origin https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/crs-2026/todo-list-aws.git
                    git push origin master
                    '''
                }
            }
        }
    }

    post {
        always {
            echo 'Limpieza general del espacio de trabajo del pipeline...'
            cleanWs()
        }
    }
}