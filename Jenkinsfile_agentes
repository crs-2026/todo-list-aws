pipeline {
    agent any // Nodo principal por defecto (para Get Code y Deploy)

    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
        AGENTE_ESTATICO    = 'static_agent' 
        AGENTE_REST        = 'rest_agent'
        // Definimos el Stack fijo de Producción para las consultas de la CLI de AWS
        STACK_NAME         = 'todo-list-aws-production'
    }

    stages {
        /*
         * ==========================================================
         * ETAPA 1: ANÁLISIS ESTÁTICO (Auditoría de Seguridad en CD)
         * ==========================================================
         */
        stage('Static Analysis') {
            agent { label "${env.AGENTE_ESTATICO}" }
            steps {
                echo "Ejecutando análisis estático en agente dedicado: ${env.NODE_NAME}"
                sh '''
                echo "=== IDENTIDAD DEL AGENTE ESTÁTICO ==="
                whoami
                hostname
                echo "======================================"
                python3 -m venv venv_estatico
                . venv_estatico/bin/activate
                pip install flake8 bandit
                flake8 src/
                bandit -r src/
                deactivate
                '''
            }
        }

        /*
         * ==========================================================
         * ETAPA 2: GET CODE (Inyección de Configuración de Producción - Reto 4)
         * ==========================================================
         */
        stage('Get Code') {
            steps {
                echo "[CD - Production] Descargando código fuente consolidado desde master..."
                checkout scm
                
                echo "[CD - Production] Descargando samconfig.toml desde la rama PRODUCTION externa..."
                // Descargamos usando curl directamente desde la rama production de tu repositorio de configuración
                sh "curl -sS https://raw.githubusercontent.com/crs-2026/todo-list-aws-config/production/samconfig.toml -o samconfig.toml"
                
                echo "=== VERIFICACIÓN DEL SAMCONFIG.TOML DE PRODUCCIÓN ==="
                sh "cat samconfig.toml"
                echo "====================================================="
            }
        }

        /*
         * ==========================================================
         * ETAPA 3: DEPLOY (Despliegue Directo a Producción con AWS SAM)
         * ==========================================================
         */
        stage('Deploy') {
            steps {
                echo "Desplegando en el entorno de PRODUCCIÓN con la configuración externa..."
                
                withCredentials([
                    string(credentialsId: 'aws-access-key', variable: 'SEC_ACCESS_KEY'),
                    string(credentialsId: 'aws-secret-key', variable: 'SEC_SECRET_KEY'),
                    string(credentialsId: 'aws-session-token', variable: 'SEC_SESSION_TOKEN')
                ]) {
                    sh '''
                    echo "=== IDENTIDAD DEL AGENTE DE DESPLIEGUE ==="
                    whoami
                    hostname
                    echo "=========================================="
                    
                    export AWS_ACCESS_KEY_ID="${SEC_ACCESS_KEY}"
                    export AWS_SECRET_ACCESS_KEY="${SEC_SECRET_KEY}"
                    export AWS_SESSION_TOKEN="${SEC_SESSION_TOKEN}"
                    export AWS_DEFAULT_REGION="us-east-1"
                    
                    sam build
                    
                    # sam deploy minimalista; extrae los parámetros automáticamente de samconfig.toml (producción)
                    sam deploy
                    
                    # Extraemos la URL generada por CloudFormation para el entorno de Producción
                    aws cloudformation describe-stacks \
                        --stack-name ${STACK_NAME} \
                        --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                        --output text > api_url.txt
                    '''
                }
                
                // Pasamos la URL de producción congelada al agente de pruebas remotas
                stash name: 'api-endpoint', includes: 'api_url.txt'
            }
        }

        /*
         * ==========================================================
         * ETAPA 4: REST TEST (Solo Lectura para Producción)
         * ==========================================================
         */
        stage('Rest Test') {
            agent { label "${env.AGENTE_REST}" }
            steps {
                echo "Arrancando pruebas de solo lectura en agente dedicado: ${env.NODE_NAME}"
                
                // Recuperamos el endpoint de producción
                unstash 'api-endpoint'
                
                sh '''
                export API_URL=$(cat api_url.txt)
                echo "URL de Producción recuperada con éxito: $API_URL"
                
                python3 -m venv venv_integration
                . venv_integration/bin/activate
                pip install pytest requests
                
                export BASE_URL=$API_URL
                
                echo "Flujo CD detectado en master: Limitando suite a pruebas de Solo Lectura..."
                # El parámetro -k "listtodos" garantiza que no alteramos datos reales de producción
                pytest -k "listtodos" --junitxml=result-production.xml test/integration/todoApiTest.py
                
                deactivate
                '''
            }
            post {
                always {
                    echo "Publicando reportes de producción en Jenkins..."
                    junit testResults: 'result-production.xml', allowEmptyResults: true
                }
            }
        }
    }

    post {
        always {
            echo 'Limpieza general del espacio de trabajo del pipeline de producción...'
            cleanWs()
        }
    }
}
