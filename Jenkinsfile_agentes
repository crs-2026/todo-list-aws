pipeline {
    agent any // Nodo principal por defecto (para Get Code y Deploy)

    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
        AGENTE_ESTATICO    = 'static_agent' 
        AGENTE_REST        = 'rest_agent'
        // Definimos el Stack fijo de Staging para las consultas de la CLI de AWS
        STACK_NAME         = 'todo-list-aws-staging'
    }

    stages {
        /*
         * ==========================================================
         * ETAPA 1: ANÁLISIS ESTÁTICO (Ejecutado en Agente Dedicado)
         * ==========================================================
         */
        stage('Static Analysis') {
            agent { label "${env.AGENTE_ESTATICO}" }
            steps {
                echo "Ejecutando análisis estático en agente dedicado: ${env.NODE_NAME}"
                sh '''
                echo "=== IDENTIDAD DEL AGENTE ESTÁTICO ==="
                whoami
                hostname
                echo "======================================"
                python3 -m venv venv_estatico
                . venv_estatico/bin/activate
                pip install flake8 bandit
                flake8 src/
                bandit -r src/
                deactivate
                '''
            }
        }

        /*
         * ==========================================================
         * ETAPA 2: GET CODE (Inyección de Configuración Externa - Reto 4)
         * ==========================================================
         */
        stage('Get Code') {
            steps {
                echo "[CI - Staging] Descargando código fuente de la aplicación..."
                checkout scm
                
                echo "[CI - Staging] Descargando archivo samconfig.toml desde la rama STAGING externa..."
                // Descargamos usando curl directamente desde la rama staging del repositorio de configuración
                sh "curl -sS https://raw.githubusercontent.com/crs-2026/todo-list-aws-config/staging/samconfig.toml -o samconfig.toml"
                
                echo "=== VERIFICACIÓN DEL SAMCONFIG.TOML DESCARGADO ==="
                sh "cat samconfig.toml"
                echo "=================================================="
            }
        }

        /*
         * ==========================================================
         * ETAPA 3: DEPLOY (Despliegue Limpio con AWS SAM)
         * ==========================================================
         */
        stage('Deploy') {
            steps {
                echo "Desplegando en el entorno de STAGING con la configuración externa..."
                
                withCredentials([
                    string(credentialsId: 'aws-access-key', variable: 'SEC_ACCESS_KEY'),
                    string(credentialsId: 'aws-secret-key', variable: 'SEC_SECRET_KEY'),
                    string(credentialsId: 'aws-session-token', variable: 'SEC_SESSION_TOKEN')
                ]) {
                    sh '''
                    echo "=== IDENTIDAD DEL AGENTE DE DESPLIEGUE ==="
                    whoami
                    hostname
                    echo "=========================================="
                    
                    export AWS_ACCESS_KEY_ID="${SEC_ACCESS_KEY}"
                    export AWS_SECRET_ACCESS_KEY="${SEC_SECRET_KEY}"
                    export AWS_SESSION_TOKEN="${SEC_SESSION_TOKEN}"
                    export AWS_DEFAULT_REGION="us-east-1"
                    
                    sam build
                    
                    # sam deploy ahora es minimalista; extrae todo del samconfig.toml de staging
                    sam deploy
                    
                    # Extraemos la URL generada por CloudFormation para usarla en los tests
                    aws cloudformation describe-stacks \
                        --stack-name ${STACK_NAME} \
                        --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                        --output text > api_url.txt
                    '''
                }
                
                // Hacemos un stash del archivo para pasárselo al agente de pruebas remotas
                stash name: 'api-endpoint', includes: 'api_url.txt'
            }
        }

        /*
         * ==========================================================
         * ETAPA 4: REST TEST (Ejecutado en Agente de Pruebas Dedicado)
         * ==========================================================
         */
        stage('Rest Test') {
            agent { label "${env.AGENTE_REST}" }
            steps {
                echo "Arrancando pruebas de API en agente dedicado: ${env.NODE_NAME}"
                
                // Recuperamos el endpoint guardado por el agente de despliegue
                unstash 'api-endpoint'
                
                sh '''
                export API_URL=$(cat api_url.txt)
                echo "URL de Staging recuperada con éxito: $API_URL"
                
                python3 -m venv venv_integration
                . venv_integration/bin/activate
                pip install pytest requests
                
                export BASE_URL=$API_URL
                
                echo "Flujo CI detectado en develop: Ejecutando la suite completa de integración (5 tests)..."
                pytest --junitxml=result-integration.xml test/integration/todoApiTest.py
                
                deactivate
                '''
            }
            post {
                always {
                    echo "Publicando reportes de integración en Jenkins..."
                    junit testResults: 'result-integration.xml', allowEmptyResults: true
                }
            }
        }

        /*
         * ==========================================================
         * ETAPA 5: PROMOTE (Fusión automática protegiendo a Producción)
         * ==========================================================
         */
        stage('Promote') {
            steps {
                echo 'Promocionando código a producción (Merge seguro de Develop -> master)...'
                
                withCredentials([usernamePassword(credentialsId: 'Jenkins', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                    sh '''
					rm -f samconfig.toml
                    rm -f api_url.txt
					git config user.name "crs"
                    
                    
                    # Sincronizamos y descargamos la rama master limpia del servidor remoto
                    git fetch origin master:master
                    git checkout master
                    
                    # Hacemos el merge de develop en master, pero detenemos el proceso antes del commit
                    git merge origin/develop --no-commit --no-edit
                    
                    # Forzamos a que master conserve su propia versión de Jenkinsfile_agentes.
                    # De esta forma, cuando master se ejecute, apuntará de forma fija a producción.
                    git checkout HEAD Jenkinsfile_agentes
                    
                    # Confirmamos el commit del Merge con los archivos protegidos
                    git commit -m "Merge branch 'develop' into master - Protegiendo configuración de producción"
                    
                    # Enviamos los cambios validados de vuelta a GitHub usando credenciales seguras
                    git remote set-url origin https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/crs-2026/todo-list-aws.git
                    git push origin master
                    '''
                }
            }
        }
    }

    post {
        always {
            echo 'Limpieza general del espacio de trabajo del pipeline...'
            cleanWs()
        }
    }
}